{
  "name": "redacted-protocol-tests",
  "version": "1.0.0",
  "description": "Integration tests for Redacted Protocol Anchor programs",
  "scripts": {
    "test":             "anchor test",
    "test:local":       "npx ts-mocha -p ./tsconfig.json -t 1000000 tests/**/*.ts",
    "lint":             "eslint tests/ --ext .ts",
    "init-presale":     "ts-node scripts/init-presale.ts",
    "launch-presale":   "ts-node scripts/launch-presale.ts",
    "create-raydium":   "ts-node scripts/create-raydium-pool.ts",
    "lock-lp":          "ts-node scripts/lock-lp.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor":  "^0.30.1",
    "@solana/web3.js":    "^1.95.0",
    "@solana/spl-token":  "^0.4.9",
    "bn.js":              "^5.2.1"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "chai": "^4.3.4",
    "mocha": "^10.0.0",
    "ts-mocha": "^10.0.0",
    "ts-node":  "^10.9.0",
    "typescript": "^5.7.0"
  }
}
