# ═══════════════════════════════════════════════════════════════
#  REDACTED PROTOCOL — Environment Configuration
#  100% FREE SETUP using OpenRouter free models
# ═══════════════════════════════════════════════════════════════

# ─── LLM — 100% FREE (OpenRouter) ────────────────────────────
# OpenRouter offers free models — no credit card required.
# Sign up: https://openrouter.ai
# Free models list: https://openrouter.ai/models?max_price=0
OPENROUTER_API_KEY=sk-or-v1-xxxx
# Free model options (no cost):
#   google/gemini-2.0-flash-exp:free
#   openai/gpt-oss-20b:free
#   meta-llama/llama-3-8b-instruct:free
#   microsoft/phi-4-mini-instruct:free
#   qwen/qwen2.5-vl-72b-instruct:free
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# ─── Paid providers (optional, if you have keys) ─────────────
# ANTHROPIC_API_KEY=sk-ant-xxxx
# OPENAI_API_KEY=sk-xxxx
# OPENAI_MODEL=gpt-4o-mini
# XAI_API_KEY=xai-xxxx
# XAI_MODEL=grok-3-fast
# DASHSCOPE_API_KEY=sk-xxxx
# DASHSCOPE_MODEL=qwen-max

# ─── Node Environment ────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
RUST_LOG=rd_core=info,rd_tools=info,rd_hooks=info,rd_providers=info

# ─── Solana Blockchain ───────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WALLET_PATH=~/.config/solana/id.json
SOLANA_NETWORK=devnet
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_WEBHOOK_URL=https://api.helius.xyz/v0/webhooks?api-key=YOUR_KEY

# ─── Token ($RDX) — Set after creating token ─────────────────
RDX_TOKEN_MINT=REPLACEME_TOKEN_MINT_ADDRESS
RDX_STAKING_PROGRAM=RDstk111111111111111111111111111111111111111
RDX_REWARDS_PROGRAM=RDrew111111111111111111111111111111111111111
RDX_TREASURY_PROGRAM=RDtr11111111111111111111111111111111111111

# ─── Permanent Storage ────────────────────────────────────────
ARWEAVE_WALLET_PATH=./wallet.json
ARWEAVE_GATEWAY=https://arweave.net
IPFS_GATEWAY=https://ipfs.io

# ─── Agent Configuration ─────────────────────────────────────
AGENT_CONFIDENCE_THRESHOLD=85
AGENT_MAX_RETRIES=3
AGENT_COOLDOWN_SECONDS=300
AGENT_MAX_CONCURRENT_JOBS=5
AGENT_HEARTBEAT_INTERVAL=30000

# ─── LLM Parameters ──────────────────────────────────────────
RECONSTRUCTION_TEMPERATURE=0.3
PUBLICATION_FREQUENCY=600

# ─── Rate Limits (per hour) ──────────────────────────────────
RATE_LIMIT_X_PER_HOUR=50
RATE_LIMIT_TELEGRAM_PER_HOUR=100
RATE_LIMIT_WEB_SCRAPE_PER_HOUR=200

# ─── Airdrop Site ──────────────────────────────────────────────
AIRDROP_SITE_URL=https://redacted-protocol.vercel.app

# ─── Monitoring (optional) ───────────────────────────────────
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/xxxx
# SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
