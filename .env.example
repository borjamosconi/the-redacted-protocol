# ─────────────────────────────────────────────────────────────
# THE REDACTED PROTOCOL - Environment Configuration Template
# ─────────────────────────────────────────────────────────────
# 
# INSTRUCTIONS:
# 1. Copy this file to .env (cp .env.example .env)
# 2. Replace ALL YOUR_* placeholders with your actual keys
# 3. NEVER commit the .env file to version control!
#
# Get your API keys from:
# - OpenRouter: https://openrouter.ai/
# - Muapi.ai: https://muapi.ai/
# - Helius: https://www.helius.dev/
# - Telegram Bot: https://t.me/BotFather
# - Upstash: https://upstash.com/
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────
# OPENROUTER API KEYS — Rotation for fault tolerance
# 3 keys to avoid rate limits and automatic fallback
# ─────────────────────────────────────────────────────────────

# KEY 1: Primary — Telegram Bot + Text reconstruction
# Recommended model: google/gemini-2.5-flash (free, fast, smart)
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_API_KEY_1_HERE
OPENROUTER_MODEL=google/gemini-2.5-flash:free

# KEY 2: Backup — Document reconstruction (more context)
# Recommended model: meta-llama/llama-3.3-70b-instruct (free, better reasoning)
OPENROUTER_API_KEY_2=sk-or-v1-YOUR_OPENROUTER_API_KEY_2_HERE
OPENROUTER_MODEL_2=meta-llama/llama-3.3-70b-instruct:free

# KEY 3: Emergency — Fallback when others fail
# Recommended model: qwen/qwen-2.5-72b-instruct (free, robust)
OPENROUTER_API_KEY_3=sk-or-v1-YOUR_OPENROUTER_API_KEY_3_HERE
OPENROUTER_MODEL_3=qwen/qwen-2.5-72b-instruct:free

# ─────────────────────────────────────────────────────────────
# IMAGE & VIDEO GENERATION
# ─────────────────────────────────────────────────────────────

# Muapi.ai — AI Image/Video Generation (200+ models)
# Used for: autonomous news images, videos, lip sync avatars, cinema shots
# Get your key at: https://muapi.ai/
MUAPI_API_KEY=YOUR_MUAPI_API_KEY_HERE

# Pollinations.ai — Free image generation (NO API KEY NEEDED)
# Used directly via URL: https://image.pollinations.ai/prompt/{prompt}

# ─────────────────────────────────────────────────────────────
# TELEGRAM BOT
# ─────────────────────────────────────────────────────────────

# Create your bot at: https://t.me/BotFather
# Send /newbot to create a new bot and get the token
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Your personal Telegram user ID (for testing)
# Get it from: https://t.me/userinfobot
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# ─────────────────────────────────────────────────────────────
# TWITTER (X) API
# ─────────────────────────────────────────────────────────────

# Create your App at: https://developer.twitter.com/en/portal/dashboard
# Required for autonomous daily tweets
TWITTER_BEARER_TOKEN=YOUR_TWITTER_BEARER_TOKEN_HERE

# ─────────────────────────────────────────────────────────────
# SOLANA BLOCKCHAIN
# ─────────────────────────────────────────────────────────────

# Solana RPC URL (devnet for testing)
# Use public devnet or get your own Helius endpoint
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Solana wallet for signing transactions (path to keypair JSON)
# Generate with: solana-keygen new -o wallet.json
SOLANA_WALLET_PATH=./wallet.json

# Deployed Fragment program ID on Solana (replace after anchor deploy)
FRAGMENT_PROGRAM_ID=RDfrag11111111111111111111111111111111111111

# Helius RPC (optional, better performance)
# Get your API key at: https://www.helius.dev/
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY_HERE

# ─────────────────────────────────────────────────────────────
# ARWEAVE STORAGE
# ─────────────────────────────────────────────────────────────

# Arweave wallet path (generate with: arweave deploy)
ARWEAVE_WALLET_PATH=./wallet.json

# Arweave gateway for viewing files
ARWEAVE_GATEWAY=https://arweave.net

# ─────────────────────────────────────────────────────────────
# AGENT CONFIGURATION
# ─────────────────────────────────────────────────────────────

# Minimum confidence threshold for publishing results (0-100)
AGENT_CONFIDENCE_THRESHOLD=85

# Maximum retries before giving up on a task
AGENT_MAX_RETRIES=3

# Cooldown between agent runs (seconds)
AGENT_COOLDOWN_SECONDS=300

# Maximum concurrent jobs
AGENT_MAX_CONCURRENT_JOBS=5

# ─────────────────────────────────────────────────────────────
# LLM PARAMETERS
# ─────────────────────────────────────────────────────────────

# Temperature for text reconstruction (0.0 = deterministic, 1.0 = creative)
RECONSTRUCTION_TEMPERATURE=0.3

# How often to check for new content to publish (seconds)
PUBLICATION_FREQUENCY=600

# ─────────────────────────────────────────────────────────────
# RATE LIMITS
# ─────────────────────────────────────────────────────────────

# Maximum actions per hour
RATE_LIMIT_X_PER_HOUR=50
RATE_LIMIT_TELEGRAM_PER_HOUR=100
RATE_LIMIT_WEB_SCRAPE_PER_HOUR=200

# ─────────────────────────────────────────────────────────────
# NODE ENVIRONMENT
# ─────────────────────────────────────────────────────────────

# Environment: development, staging, production
NODE_ENV=development

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Rust module log levels
RUST_LOG=rd_core=info,rd_tools=info,rd_hooks=info,rd_providers=info

# ─────────────────────────────────────────────────────────────
# MONITORING (Optional)
# ─────────────────────────────────────────────────────────────

# Discord webhook for alerts (optional)
# Create a webhook in your Discord server settings
DISCORD_WEBHOOK_URL=

# Sentry DSN for error tracking (optional)
# Get from: https://sentry.io/
SENTRY_DSN=
