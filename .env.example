# Redacted Protocol Agent - Production Environment Setup
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control

# =============================================================================
# LLM PROVIDERS (at least one required)
# =============================================================================

# OpenRouter (Recommended - Free tier, no credit card needed)
# Sign up: https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Anthropic Claude (Paid)
# Sign up: https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI GPT (Paid)
# Sign up: https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# xAI Grok (Paid)
# Sign up: https://console.x.ai
XAI_API_KEY=
XAI_MODEL=grok-3-fast

# =============================================================================
# TELEGRAM BOT
# =============================================================================

# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Get your chat ID via Telegram API or @userinfobot
TELEGRAM_CHAT_ID=

# =============================================================================
# SOLANA (Devnet for testing, Mainnet for production)
# =============================================================================

SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
# Optional: Helius RPC for faster indexing
HELIUS_RPC_URL=

# =============================================================================
# ARWEAVE
# =============================================================================

ARWEAVE_WALLET_PATH=./wallet.json
ARWEAVE_GATEWAY=https://arweave.net

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================

AGENT_CONFIDENCE_THRESHOLD=85
AGENT_MAX_RETRIES=3
AGENT_COOLDOWN_SECONDS=300
AGENT_MAX_CONCURRENT_JOBS=5

# =============================================================================
# LLM PARAMETERS
# =============================================================================

RECONSTRUCTION_TEMPERATURE=0.3
PUBLICATION_FREQUENCY=600

# =============================================================================
# RATE LIMITS
# =============================================================================

RATE_LIMIT_X_PER_HOUR=50
RATE_LIMIT_TELEGRAM_PER_HOUR=100
RATE_LIMIT_WEB_SCRAPE_PER_HOUR=200

# =============================================================================
# LOGGING & MONITORING
# =============================================================================

NODE_ENV=production
LOG_LEVEL=info
RUST_LOG=rd_core=info,rd_tools=info,rd_hooks=info,rd_providers=info

# Optional: Discord webhook for alerts
DISCORD_WEBHOOK_URL=

# Optional: Sentry for error tracking
SENTRY_DSN=
