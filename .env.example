# Redacted Protocol Agent - Environment Setup

# OpenRouter (Free LLM access - no credit card needed)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Telegram Bot
TELEGRAM_BOT_TOKEN=8716267729:AAHI0FI1o3jRMv13ideBl0K1f_nNkasth2Y
TELEGRAM_CHAT_ID=your_chat_id_here

# Solana (Devnet for testing)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
HELIUS_RPC_URL=your_helius_key_here

# Arweave
ARWEAVE_WALLET_PATH=./wallet.json
ARWEAVE_GATEWAY=https://arweave.net

# Agent Configuration
AGENT_CONFIDENCE_THRESHOLD=85
AGENT_MAX_RETRIES=3
AGENT_COOLDOWN_SECONDS=300
AGENT_MAX_CONCURRENT_JOBS=5

# LLM Parameters
RECONSTRUCTION_TEMPERATURE=0.3
PUBLICATION_FREQUENCY=600

# Rate Limits
RATE_LIMIT_X_PER_HOUR=50
RATE_LIMIT_TELEGRAM_PER_HOUR=100
RATE_LIMIT_WEB_SCRAPE_PER_HOUR=200

# Node Environment
NODE_ENV=development
LOG_LEVEL=info
RUST_LOG=rd_core=info,rd_tools=info,rd_hooks=info,rd_providers=info

# Monitoring (Optional)
DISCORD_WEBHOOK_URL=
SENTRY_DSN=
