{
  "version": 2,
  "name": "the-redacted-protocol",
  "framework": "nextjs",
  "regions": ["sfo1"],
  "env": {
    "NEXT_PUBLIC_BONDING_CURVE_PROGRAM_ID": "2zj6YEu1jYf2En29CHJdCppyhbBmzuAT9zN4Qr9Vkhyg",
    "NEXT_PUBLIC_LAUNCH_MODE": "onchain",
    "NEXT_PUBLIC_BACKEND_URL": "https://api.redacted.bond"
  },
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "routes": [
