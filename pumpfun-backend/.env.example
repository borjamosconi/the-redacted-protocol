# ─── Core ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=change-me-to-a-long-random-string

# ─── MongoDB ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/redacted

# ─── Solana RPC ─────────────────────────────────────────────────────────────
# Mainnet: https://api.mainnet-beta.solana.com  (or Helius/Triton)
# Devnet : https://api.devnet.solana.com
SOLANA_RPC=https://api.mainnet-beta.solana.com
SOLANA_CLUSTER=mainnet-beta
# base58 secret key for the service wallet (migration authority + signer for graduations)
ADMIN_PRIVATE_KEY=

# ─── Program IDs (replace after `anchor build && anchor deploy`) ────────────
RD_BONDINGCURVE_PROGRAM_ID=BCurve1111111111111111111111111111111111111
RD_TOKEN_PROGRAM_ID=CPLCsPQJrfWQgacJEq1QcbwoMcJocbEhjGVmJLPhs38Z
RD_TREASURY_PROGRAM_ID=HpvmQtmxyPeeYKGvKHqEdcnsYUzAQrdynoCX452s2xLz
RD_PRESALE_PROGRAM_ID=HACK1L8hdDN1wuhV5mEbNYGeMXjhFzvz3HNvDTCdFP2a

# ─── Treasury / Vault ───────────────────────────────────────────────────────
TREASURY_PUBKEY=CMESXEN77tCC6ndjVBmHEuY1fg86X6GWkEvFiMfKc5X8
MIGRATION_AUTHORITY_PUBKEY=

# ─── Pinata (optional — IPFS uploads for token metadata) ────────────────────
